# One UI Studio — environment variables
# Copy this file to .env.local and fill in real values.
# .env.local is gitignored.

# ─── Convex backend (required) ─────────────────────────────────────────
# URL of your Convex deployment. Get it from `npx convex dev`.
NEXT_PUBLIC_CONVEX_URL=

# Storybook (apps/storybook) — Convex URL for live brand CSS injection.
# Takes priority over NEXT_PUBLIC_CONVEX_URL (see .storybook/main.ts).
#
# IMPORTANT: point this at the PRODUCTION Convex deployment
# (https://robust-stoat-734.convex.cloud) — that is where the real brands and
# their uploaded custom fonts live. A LAB/dev deployment has the brand records
# but NO uploaded font files, so typography silently falls back to system fonts.
# Storybook only reads data (never writes), and brand/token reads are open to
# anonymous callers, so pointing at prod is safe.
# Transparent material is always ON in Storybook (see apps/storybook/.storybook/main.ts).
STORYBOOK_CONVEX_URL=https://robust-stoat-734.convex.cloud

# Sandboxed Storybook mode — skips Convex entirely and loads brand foundations
# from @jds/kb-core/dist/brands/<slug>.json. Set this in CI jobs that produce
# visual-signature artefacts (packages/kb-web/scripts/generate-visual-signatures.ts)
# or in any other Convex-less environment. Leave unset for normal local dev.
#
#   STORYBOOK_OFFLINE=1
#   STORYBOOK_OFFLINE_BRAND=jio-mobile     # optional; defaults to jio-mobile
STORYBOOK_OFFLINE=
STORYBOOK_OFFLINE_BRAND=

# Mobile (Expo) consumes the same Convex deployment. Set in `apps/mobile/.env.local`.
# Expo only exposes `EXPO_PUBLIC_*` env vars to the client bundle.
EXPO_PUBLIC_CONVEX_URL=

# ─── AI providers ──────────────────────────────────────────────────────
# Required for /api/agent chat, voice eval runs, and tone-of-voice features.
ANTHROPIC_API_KEY=

# Required for RAG (apps/platform/src/lib/rag.ts) and knowledge ingestion.
OPENAI_API_KEY=

# ─── Auth (Better Auth via @convex-dev/better-auth) ───────────────────
# Replaces the old shared SITE_PASSWORD gate with real per-user accounts.
# Secret for Better Auth (token signing). Generate with: openssl rand -hex 32
# Set in the Convex deployment env:  npx convex env set BETTER_AUTH_SECRET <value>
BETTER_AUTH_SECRET=

# Public site origin — Better Auth baseURL + OAuth callback origin.
# SITE_URL is set in the Convex deployment env; NEXT_PUBLIC_SITE_URL in .env.local.
SITE_URL=http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Convex HTTP actions origin (….convex.site) — from `npx convex dev` output.
NEXT_PUBLIC_CONVEX_SITE_URL=

# Optional Google OAuth — set BOTH in the Convex deployment env to enable the
# "Continue with Google" button (npx convex env set GOOGLE_CLIENT_ID <id> …).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Figma ───────────────────────────────────────────────────────────
# Personal access token (Figma → Settings → Security → Personal access tokens).
# Used by CLI parity scripts: `pnpm generate:figma-parity-fixture`, `pnpm figma-matrix:fetch`.
# Set in repo-root `.env.local` and/or `apps/platform/.env.local` (both gitignored).
FIGMA_ACCESS_TOKEN=

# OAuth (optional — platform app brand ↔ Figma file linking via /api/auth/figma/*)
FIGMA_CLIENT_ID=
FIGMA_CLIENT_SECRET=
FIGMA_REDIRECT_URI=

# Symmetric key used to encrypt stored Figma access tokens in Convex.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# ─── Supabase (optional — only for theme smoke scripts) ───────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ─── Notion Bug Tracker (QA Dashboard — apps/qa-playground) ───────────
# Integration token: Notion → Settings → Connections → Develop integration.
# Share your Bugs database with the integration, then copy the database ID from the URL.
NOTION_API_KEY=
# From database URL: https://notion.so/.../<THIS_ID>?v=...
NOTION_DATABASE_ID=
# Defaults match "OneUI Component Bugs" workspace DB — override if needed:
# NOTION_PROP_TITLE=Bug Title
# NOTION_PROP_BUG_ID=Bug Key
# NOTION_PROP_SEVERITY=Severity
# NOTION_PROP_STATUS=Bug Status
# NOTION_PROP_DEV_STATUS=Dev Status
# NOTION_PROP_PLATFORM=Platform
# NOTION_PROP_CATEGORY=Category
# NOTION_PROP_ASSIGNEE=Assignee
# NOTION_PROP_REPORTED_BY=Reported By
# NOTION_PROP_RELEASE=Release
# Set to 1 if Node fetch fails with TLS/certificate errors (common on corporate Macs):
# NOTION_USE_CURL=1

# ─── Personalization (optional) ────────────────────────────────────────
# Displayed in HomeChat greeting.
NEXT_PUBLIC_USER_NAME=

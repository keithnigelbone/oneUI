{
  "name": "@oneui/native-components-sample",
  "version": "0.1.0",
  "private": true,
  "main": "index.ts",
  "scripts": {
    "dev": "expo start --dev-client",
    "dev:go": "expo start --go",
    "dev:both": "expo start --dev-client --ios --android",
    "ios": "bash scripts/with-android-jdk.sh expo run:ios",
    "android": "bash scripts/with-android-jdk.sh expo run:android",
    "android:metro": "bash scripts/android-fix-convex-network.sh && expo start --dev-client --android",
    "android:network": "bash scripts/android-fix-convex-network.sh",
    "convex:local": "pnpm --filter @oneui/convex dev",
    "prebuild": "expo prebuild",
    "postinstall": "bash scripts/patch-rn-gradle-jdk.sh && bash scripts/ensure-android-local-properties.sh",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "export:brands": "pnpm -C ../.. exec tsx apps/native-components-sample/scripts/exportBrandData.ts",
    "stamp:version": "pnpm -C ../.. exec tsx apps/native-components-sample/scripts/stampBrandDataVersion.ts",
    "migrate:brand-data": "pnpm -C ../.. exec tsx apps/native-components-sample/scripts/migrateBrandDataStructure.ts"
  },
  "dependencies": {
    "@expo/metro-runtime": "~6.1.2",
    "@jds/core-icons--react-native": "file:./vendor/jds-core-icons--react-native-0.0.5.tgz",
    "@oneui/native-cdn": "file:./vendor/oneui-native-cdn-0.1.0-alpha.3.tgz",
    "@oneui/convex": "workspace:*",
    "@oneui/shared": "workspace:*",
    "@oneui/tokens": "workspace:*",
    "@oneui/ui": "workspace:*",
    "@oneui/icons-jio-native": "workspace:*",
    "@oneui/ui-native": "workspace:*",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/native": "^7.0.0",
    "@react-navigation/native-stack": "^7.0.0",
    "convex": "^1.39.1",
    "expo": "~54.0.0",
    "expo-dev-client": "~6.0.21",
    "expo-font": "~14.0.11",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@expo/config-plugins": "~54.0.4",
    "@types/react": "~19.1.10",
    "typescript": "^5.7.2",
    "@types/node": "^22.10.0"
  }
}

{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM"],
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "types": ["react", "react-native", "node"],
    "paths": {
      "@oneui/shared": ["../../packages/shared/src"],
      "@oneui/shared/engine": ["../../packages/shared/src/engine"],
      "@oneui/tokens": ["../../packages/tokens/src"],
      "@oneui/ui-native": ["../../packages/ui-native/src"],
      "@oneui/ui-native/theme": ["../../packages/ui-native/src/theme"],
      "@oneui/ui-native/icons": ["../../packages/ui-native/src/components/Icon/icons.ts"],
      "@oneui/ui-native/components/*": ["../../packages/ui-native/src/components/*"]
    }
  },
  "include": ["**/*.ts", "**/*.tsx", "declarations.d.ts"],
  "exclude": ["node_modules"]
}

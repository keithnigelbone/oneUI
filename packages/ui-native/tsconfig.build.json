{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "allowJs": false,
    "strict": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "declaration": true,
    "declarationMap": true,
    "sourceMap": false,
    "noEmit": false,
    "incremental": false,
    "composite": false,
    "rootDir": "./src",
    "outDir": "../../dist/packages/ui-native"
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "src/**/__tests__/**/*",
    "src/**/*.showcase.native.tsx",
    "src/**/ButtonPreview.native.tsx",
    "src/**/*ShowcaseGlyphs.tsx",
    "src/**/*ShowcaseJds*.tsx"
  ]
}

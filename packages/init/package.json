{
  "name": "@oneui/init",
  "version": "0.1.0-alpha.10",
  "private": false,
  "type": "module",
  "main": "./src/bin.ts",
  "bin": {
    "oneui-init": "./src/bin.ts"
  },
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "bin": {
      "oneui-init": "./dist/bin.mjs"
    },
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "tsup": "^8.0.0",
    "typescript": "^5.7.2"
  }
}

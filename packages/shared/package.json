{
  "name": "@oneui/shared",
  "version": "0.1.0-alpha.0",
  "private": false,
  "type": "module",
  "sideEffects": false,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "files": [
    "dist"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./types/*": "./src/types/*.ts",
    "./constants/*": "./src/constants/*.ts",
    "./utils/*": "./src/utils/*.ts",
    "./data/*": "./src/data/*.ts",
    "./engine": "./src/engine/index.ts",
    "./engine/*": "./src/engine/*.ts",
    "./codegen": "./src/codegen/index.ts",
    "./codegen/*": "./src/codegen/*.ts",
    "./templates": "./src/templates/index.ts",
    "./templates/*": "./src/templates/*.ts",
    "./meta": "./src/meta/index.ts",
    "./meta/generated/*": "./src/meta/generated/*.ts",
    "./agent": "./src/agent/index.ts",
    "./cdn": "./src/cdn/index.ts"
  },
  "publishConfig": {
    "main": "./dist/index.cjs",
    "module": "./dist/index.mjs",
    "types": "./dist/index.d.ts",
    "exports": {
      ".": {
        "types": "./dist/index.d.ts",
        "import": "./dist/index.mjs",
        "require": "./dist/index.cjs"
      },
      "./engine": {
        "types": "./dist/engine/index.d.ts",
        "import": "./dist/engine/index.mjs",
        "require": "./dist/engine/index.cjs"
      },
      "./meta": {
        "types": "./dist/meta/index.d.ts",
        "import": "./dist/meta/index.mjs",
        "require": "./dist/meta/index.cjs"
      },
      "./codegen": {
        "types": "./dist/codegen/index.d.ts",
        "import": "./dist/codegen/index.mjs",
        "require": "./dist/codegen/index.cjs"
      },
      "./templates": {
        "types": "./dist/templates/index.d.ts",
        "import": "./dist/templates/index.mjs",
        "require": "./dist/templates/index.cjs"
      },
      "./agent": {
        "types": "./dist/agent/index.d.ts",
        "import": "./dist/agent/index.mjs",
        "require": "./dist/agent/index.cjs"
      },
      "./cdn": {
        "types": "./dist/cdn/index.d.ts",
        "import": "./dist/cdn/index.mjs",
        "require": "./dist/cdn/index.cjs"
      }
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "pack:dist": "node -e \"require('fs').mkdirSync('../../dist/packages/shared',{recursive:true})\" && npm pack --pack-destination ../../dist/packages/shared",
    "build:pack": "pnpm run build && pnpm run pack:dist"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@babel/generator": "^7.29.1",
    "@babel/parser": "^7.29.2",
    "@babel/traverse": "^7.29.0",
    "@babel/types": "^7.29.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/babel__generator": "^7.27.0",
    "@types/babel__traverse": "^7.28.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.2.0",
    "ajv": "^8.17.1",
    "react": "^19.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.2",
    "vitest": "^2.0.0"
  }
}

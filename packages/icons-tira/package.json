    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.0",
    "react": "^19.2.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.2"
  }
}

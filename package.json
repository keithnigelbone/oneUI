    "docs:stop": "lsof -tiTCP:3001 -sTCP:LISTEN | xargs kill -9 || true",
    "docs:serve": "pnpm docs:stop && sleep 1 && pnpm --filter @oneui/docs start",
    "docs:preview": "pnpm docs:stop && sleep 1 && pnpm docs:clean && pnpm build:docs && pnpm --filter @oneui/docs start",
    "docs:components": "pnpm --filter @oneui/docs generate:component-docs",

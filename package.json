    "seed:voice:eval": "tsx scripts/seed-voice-eval-scenarios.ts",
    "ingest:knowledge": "tsx scripts/ingest-knowledge.ts",
    "embed:composition": "tsx scripts/embed-composition.ts",
    "clean": "turbo clean && rm -rf node_modules",
    "clear-cache": "bash scripts/clear-cache.sh",
    "format": "prettier --write \"**/*.{ts,tsx,md,json,css}\"",
    "lint": "eslint ."

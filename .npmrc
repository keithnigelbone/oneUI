# pnpm configuration
shamefully-hoist=false
strict-peer-dependencies=false

# vite-plugin-dts → @vue/language-core requires @vue/shared at runtime via a
# bare `require('@vue/shared')`. Without hoisting, pnpm's isolated store hides
# it from language-core and `pnpm dev` / `pnpm build` fails on packages/ui.
public-hoist-pattern[]=@vue/shared

# Keep expo-dev-client scoped to apps/mobile only — prevents Expo Go projects
# (e.g. native-components-sample) from detecting a dev build and logging warnings.
public-hoist-pattern[]=!expo-dev-client

# Expo's @expo/metro-config (file-store.ts) reaches into metro-cache via a
# deep require that bypasses metro-cache's `exports` map. With pnpm's default
# isolated linker, Node's `exports` enforcement rejects the require and
# `expo start` crashes with ERR_PACKAGE_PATH_NOT_EXPORTED. Switch the
# whole monorepo to a hoisted (npm-style flat) node_modules so the deep
# require resolves the way Expo's tooling expects.
node-linker=hoisted
